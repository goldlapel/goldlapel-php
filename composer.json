{
  "name": "goldlapel/goldlapel",
  "description": "Self-optimizing Postgres proxy — automatic materialized views and indexes",
  "type": "library",
  "license": "MIT",
  "homepage": "https://goldlapel.com",
  "keywords": ["postgres", "proxy", "optimization", "materialized-views", "database"],
  "authors": [
    {
      "name": "Gold Lapel",
      "homepage": "https://goldlapel.com"
    }
  ],
  "support": {
    "issues": "https://github.com/goldlapel/goldlapel-php/issues",
    "source": "https://github.com/goldlapel/goldlapel-php"
  },
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5.22",
    "orchestra/testbench": "^8.0 || ^9.0 || ^10.0",
    "amphp/postgres": "^2.2"
  },
  "suggest": {
    "illuminate/support": "Required for Laravel integration (>=10.0)",
    "amphp/postgres": "Required for the native async API under GoldLapel\\Amp\\ (^2.2)"
  },
  "autoload": {
    "psr-4": {
      "GoldLapel\\": "src/",
      "GoldLapel\\Laravel\\": "src/Laravel/",
      "GoldLapel\\Amp\\": "src/Amp/"
    },
    "files": [
      "src/Laravel/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "GoldLapel\\Tests\\": "tests/",
      "GoldLapel\\Laravel\\Tests\\": "tests/Laravel/",
      "GoldLapel\\Amp\\Tests\\": "tests/Amp/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "GoldLapel\\Laravel\\GoldLapelServiceProvider"
      ]
    }
  },
  "bin": [
    "bin/goldlapel"
  ],
  "version": "0.2.0"
}
