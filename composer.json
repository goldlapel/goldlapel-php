{
  "name": "goldlapel/goldlapel",
  "description": "PHP wrapper for the Gold Lapel self-optimizing Postgres proxy",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0 || ^11.0"
  },
  "autoload": {
    "psr-4": {
      "GoldLapel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "GoldLapel\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/goldlapel"
  ],
  "version": "0.1.0-rc6"
}
